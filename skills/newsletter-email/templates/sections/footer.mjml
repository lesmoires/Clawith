<mj-section background-color="{{colors.surface}}" css-class="dark-surface" padding="16px 0">
  <mj-column width="100%">
    <mj-divider border-color="{{colors.border}}" padding="8px 0" />
    <mj-text font-family="{{fonts.body}}" color="{{colors.text_muted}}" font-size="11px" align="center" css-class="dark-text-muted">{{display_name}} {{agency_tagline}}</mj-text>
    <mj-text font-family="{{fonts.body}}" color="{{colors.text_muted}}" font-size="10px" align="center" padding="4px 0 0 0" css-class="dark-text-muted">{{footer_note}}</mj-text>
  </mj-column>
</mj-section>
